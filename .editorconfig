# EditorConfig — consistent formatting across all editors.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C / C++ engine sources: 4-space indent, 100 columns (mirrors .clang-format).
[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,inl}]
indent_size = 4
max_line_length = 100

# Rust tooling: rustfmt's defaults are 4 spaces.
[*.rs]
indent_size = 4
max_line_length = 100

# CMake and YAML conventionally use 2 spaces.
[{CMakeLists.txt,*.cmake}]
indent_size = 2

[*.{yml,yaml,toml}]
indent_size = 2

# Markdown: don't trim trailing whitespace (two trailing spaces = hard line break).
[*.md]
trim_trailing_whitespace = false

# Makefiles require real tabs.
[Makefile]
indent_style = tab
